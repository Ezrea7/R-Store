[Script]
vvebo = type=http-response,pattern=^https?:\/\/api\.weibo\.cn\/2\/users\/show\?,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/Ezrea7/R-Store/main/Res/Scripts/AntiAd/vvebo.js
vvebo = type=http-response,pattern=^https?:\/\/api\.weibo\.cn\/2\/statuses\/user_timeline\?,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/Ezrea7/R-Store/main/Res/Scripts/AntiAd/vvebo.js
vvebo = type=http-response,pattern=^https?:\/\/api\.weibo\.cn\/2\/remind\/unread_count\?,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/Ezrea7/R-Store/main/Res/Scripts/AntiAd/vvebo.js
vvebo = type=http-response,pattern=^https?:\/\/api\.weibo\.cn\/2\/profile\/statuses\/tab\?,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/Ezrea7/R-Store/main/Res/Scripts/AntiAd/vvebo.js
vvebo = type=http-response,pattern=^https?:\/\/api\.weibo\.cn\/2\/cardlist\?,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/Ezrea7/R-Store/main/Res/Scripts/AntiAd/vvebo.js

[MITM]
hostname= %APPEND% api.weibo.cn